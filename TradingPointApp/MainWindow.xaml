<Window x:Class="TradingPointApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TradingPointApp.ViewModels"
        mc:Ignorable="d"
        Title="Симулятор Торговой Точки" Height="620" Width="1050"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Область симуляции -->
        <Border Grid.Column="0" Margin="5" BorderBrush="#888" BorderThickness="1" CornerRadius="3">
            <Grid>
                <Canvas x:Name="SimulationCanvas" Background="#F5F8F5" ClipToBounds="True"
                        SizeChanged="SimulationCanvas_SizeChanged">

                    <!-- Торговые точки -->
                    <ItemsControl ItemsSource="{Binding TradingPoints}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Border Width="64" Height="54" Background="#4CAF50"
                                            CornerRadius="5" BorderBrush="#2E7D32" BorderThickness="2">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="&#x1F3EA;" FontSize="22"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" FontSize="10"
                                               HorizontalAlignment="Center" FontWeight="SemiBold"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Покупатели -->
                    <ItemsControl ItemsSource="{Binding Customers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Ellipse Width="22" Height="22" Fill="#1976D2"
                                             Stroke="#0D47A1" StrokeThickness="1.5"/>
                                    <TextBlock Text="{Binding Name}" FontSize="8"
                                               HorizontalAlignment="Center"
                                               Foreground="#333" Margin="0,1,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>
            </Grid>
        </Border>

        <!-- Панель управления -->
        <Border Grid.Column="1" Margin="0,5,5,5" Background="#FAFAFA"
                BorderBrush="#CCC" BorderThickness="1" CornerRadius="3">
            <DockPanel Margin="10">
                <!-- Кнопки управления -->
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Управление" FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Button Content="Добавить торговую точку"
                            Command="{Binding AddTradingPointCommand}"
                            Padding="8,6" Margin="0,3" FontSize="13"/>

                    <Button Content="Добавить покупателя"
                            Command="{Binding AddCustomerCommand}"
                            Padding="8,6" Margin="0,3" FontSize="13"/>

                    <Separator Margin="0,8"/>

                    <Button Content="Запустить симуляцию"
                            Command="{Binding StartSimulationCommand}"
                            Padding="8,6" Margin="0,3" FontSize="13"
                            Background="#C8E6C9" BorderBrush="#4CAF50"/>

                    <Button Content="Остановить симуляцию"
                            Command="{Binding StopSimulationCommand}"
                            Padding="8,6" Margin="0,3" FontSize="13"
                            Background="#FFCDD2" BorderBrush="#F44336"/>

                    <Separator Margin="0,8"/>

                    <Button Content="Информация (Reflection)"
                            Command="{Binding ShowReflectionInfoCommand}"
                            Padding="8,6" Margin="0,3" FontSize="12"/>
                </StackPanel>

                <!-- Журнал событий -->
                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,5">
                    <TextBlock Text="Журнал событий" FontSize="14" FontWeight="Bold"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding LogMessages}"
                         FontSize="11" FontFamily="Consolas"
                         BorderBrush="#CCC" BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                       MaxWidth="260"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>
